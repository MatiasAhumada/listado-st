// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPRESA
  VENDEDOR
  TECNICO
}

enum ProductType {
  MODULO
  BATERIA
  PIN
  VARIOS
}

enum ProductQuality {
  INCELL
  OLED
  ORIGINAL
  SERVICEPACK
  REMANOFACTURADO
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos Producto[]
  company   User?     @relation("CompanyVendedores", fields: [companyId], references: [id])
  vendedores User[]   @relation("CompanyVendedores")

  @@map("users")
}

model Producto {
  id               String          @id @default(uuid())
  name             String
  type             ProductType
  quality          ProductQuality?
  available        Boolean         @default(true)
  costTech         Float           @default(0)
  costTechMargin   Float           @default(0)
  cost             Float
  costMargin       Float           @default(0)
  cash             Float
  cashMargin       Float           @default(0)
  credit           Float
  creditMargin     Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  masterProductId  String?
  masterProduct    Producto?  @relation("ProductoCopias", fields: [masterProductId], references: [id], onDelete: Cascade)
  copias           Producto[] @relation("ProductoCopias")

  companyId String?
  company   User?   @relation(fields: [companyId], references: [id])

  @@map("productos")
}
