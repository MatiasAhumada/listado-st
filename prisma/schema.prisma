// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPRESA
  VENDEDOR
  TECNICO
}

enum ProductType {
  MODULO
  BATERIA
  PIN
  CONSOLA
  MANTENIMIENTO
  VIDRIOS_CAMARA
  VARIOS
}

enum ServiceOrderStatus {
  RECEPCIONADO
  RETIRADO_POR_TECNICO
  DEVUELTO_POR_TECNICO
  ENTREGADO_A_CLIENTE
  COBRADO
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  role       Role     @default(VENDEDOR)
  companyId  String?
  branchId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productos     Producto[]
  serviceOrders ServiceOrder[]
  company       User?          @relation("CompanyVendedores", fields: [companyId], references: [id])
  vendedores    User[]         @relation("CompanyVendedores")
  branch        Branch?        @relation(fields: [branchId], references: [id])
  branches      Branch[]       @relation("CompanyBranches")
  clients       Client[]

  @@map("users")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   User   @relation("CompanyBranches", fields: [companyId], references: [id], onDelete: Cascade)

  vendedores    User[]
  serviceOrders ServiceOrder[]

  @@map("branches")
}

model Producto {
  id               String          @id @default(uuid())
  name             String
  type             ProductType
  available        Boolean         @default(true)
  costTech         Float           @default(0)
  costTechMargin   Float           @default(0)
  cost             Float
  costMargin       Float           @default(0)
  cash             Float
  cashMargin       Float           @default(0)
  credit           Float
  creditMargin     Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  masterProductId  String?
  masterProduct    Producto?  @relation("ProductoCopias", fields: [masterProductId], references: [id], onDelete: Cascade)
  copias           Producto[] @relation("ProductoCopias")

  companyId String?
  company   User?   @relation(fields: [companyId], references: [id])

  @@map("productos")
}

model Client {
  id        String   @id @default(uuid())
  fullName  String
  dni       String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   User   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  serviceOrders ServiceOrder[]

  @@unique([companyId, dni])
  @@map("clients")
}

model ServiceOrder {
  id                String             @id @default(uuid())
  clientName        String
  clientPhone       String
  advancePayment    Int                @default(0)
  balance           Int                @default(0)
  deliveryDate      DateTime?
  status            ServiceOrderStatus @default(RECEPCIONADO)
  receivedAt        DateTime           @default(now())
  pickedUpAt        DateTime?
  returnedAt        DateTime?
  deliveredAt       DateTime?
  paidAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  companyId String
  company   User   @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  images   ServiceOrderImage[]
  products ServiceOrderProduct[]

  @@map("service_orders")
}

model ServiceOrderProduct {
  id             String      @id @default(uuid())
  unitPrice      Float
  totalPrice     Float
  isDry          Boolean     @default(false)
  hasImpact      Boolean     @default(false)
  isBrokenScreen Boolean     @default(false)
  isTurnedOn     Boolean     @default(false)
  isCharging     Boolean     @default(false)
  color          String?
  description    String?     @db.Text
  createdAt      DateTime    @default(now())

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  productName String
  productType ProductType

  @@map("service_order_products")
}

model ServiceOrderImage {
  id             String   @id @default(uuid())
  url            String
  uploadedAt     DateTime @default(now())

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@map("service_order_images")
}
