// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPRESA
  VENDEDOR
  TECNICO
}

enum ProductType {
  MODULO
  BATERIA
  PIN
  CONSOLA
  MANTENIMIENTO
  VIDRIOS_CAMARA
  VARIOS
}

enum ServiceOrderStatus {
  RECEPCIONADO
  RETIRADO_POR_TECNICO
  DEVUELTO_POR_TECNICO
  ENTREGADO_A_CLIENTE
  COBRADO
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos     Producto[]
  serviceOrders ServiceOrder[]
  company       User?          @relation("CompanyVendedores", fields: [companyId], references: [id])
  vendedores    User[]         @relation("CompanyVendedores")

  @@map("users")
}

model Producto {
  id               String          @id @default(uuid())
  name             String
  type             ProductType
  available        Boolean         @default(true)
  costTech         Float           @default(0)
  costTechMargin   Float           @default(0)
  cost             Float
  costMargin       Float           @default(0)
  cash             Float
  cashMargin       Float           @default(0)
  credit           Float
  creditMargin     Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  masterProductId  String?
  masterProduct    Producto?  @relation("ProductoCopias", fields: [masterProductId], references: [id], onDelete: Cascade)
  copias           Producto[] @relation("ProductoCopias")

  companyId String?
  company   User?   @relation(fields: [companyId], references: [id])

  @@map("productos")
}

model ServiceOrder {
  id                String             @id @default(uuid())
  clientName        String
  clientPhone       String
  deviceModel       String
  deviceIssue       String
  estimatedCost     Float
  finalCost         Float?
  status            ServiceOrderStatus @default(RECEPCIONADO)
  receivedAt        DateTime           @default(now())
  pickedUpAt        DateTime?
  returnedAt        DateTime?
  deliveredAt       DateTime?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  companyId String
  company   User   @relation(fields: [companyId], references: [id])

  images ServiceOrderImage[]

  @@map("service_orders")
}

model ServiceOrderImage {
  id             String   @id @default(uuid())
  url            String
  uploadedAt     DateTime @default(now())

  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@map("service_order_images")
}
